# Discord application credentials (never commit real values)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Lavalink connection
LAVALINK_HOST=lavalink
LAVALINK_PORT=2333
LAVALINK_PASSWORD=
LAVALINK_SECURE=false

# Optional OpenAI-compatible AI provider
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# Dashboard / API authentication
DASHBOARD_SECRET=
DATABASE_URL=sqlite:///data/db/discord_penguin.db

# Read-only music status snapshot (Phase 2B). Defaults are set in docker-compose;
# override only for local non-Docker runs. The snapshot is a runtime-only file
# under ./tmp and must never be committed.
# MUSIC_STATUS_SNAPSHOT_PATH=/runtime/music-status/status.json
# MUSIC_STATUS_STALE_AFTER_MS=15000
